{
  "$schema": "https://v2-10-0.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".wrangler/deploy/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["CLOUDFLARE_API_TOKEN"]
    },
    "tsc:check": {
      "dependsOn": ["^build", "^tsc:check"],
      "outputs": []
    }
  }
}