{
  "name": "moduix-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:docs": "turbo run build -F moduix-docs",
    "build:ui": "turbo run build -F moduix",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:release": "turbo run build -F moduix && changeset publish",
    "deploy:docs": "turbo run deploy -F moduix-docs",
    "dev": "turbo run dev",
    "fmt:check": "oxfmt --check",
    "fmt:fix": "oxfmt",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "husky",
    "publish:ui": "npm publish -w moduix",
    "tsc:check": "turbo run tsc:check"
  },
  "dependencies": {
    "rollup-plugin-copy": "^3.5.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@storybook/react-vite": "^10.3.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "storybook": "^10.3.6",
    "turbo": "^2.9.12"
  },
  "packageManager": "npm@11.14.1"
}