# An .aiignore file follows the same syntax as a .gitignore file.
# Docs: https://git-scm.com/docs/gitignore

# OS / editor noise
.DS_Store
Thumbs.db

# Logs and temp files
*.log
*.tmp
*.temp
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment and local secrets
.env
.env.*
!.env.example

# Build output / coverage
dist/
build/
out/
coverage/

# Tooling caches
.turbo/
.cache/
*.tsbuildinfo

# Documentation/app artifacts
apps/docs/.wrangler/
