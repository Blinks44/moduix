{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["**/*.gen.ts", "wrangler.jsonc", "package-lock.json"],
  "singleQuote": true,
  "semi": true,
  "sortImports": {
    "internalPattern": ["@/", "components/", "data/", "icons/", "lib/"],
    "newlinesBetween": false,
    "sortSideEffects": true,
    "groups": [
      ["type-builtin", "value-builtin", "type-external", "value-external"],
      ["type-internal", "value-internal"],
      [
        "type-parent",
        "value-parent",
        "type-sibling",
        "value-sibling",
        "type-index",
        "value-index",
        "style"
      ],
      "unknown"
    ]
  }
}