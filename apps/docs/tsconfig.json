{
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["vite/client"],
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/lib/moduix/icons/ui": ["../../packages/react/src/icons/ui"],
      "@/lib/moduix/icons/ui/*": ["../../packages/react/src/icons/ui/*"],
      "@/lib/moduix": ["../../packages/react/src/core/lib/moduix"],
      "@/lib/moduix/*": ["../../packages/react/src/core/lib/moduix/*"],
      "@/*": ["./src/*"],
      "collections/*": ["./.source/*"]
    },
    "noEmit": true
  }
}