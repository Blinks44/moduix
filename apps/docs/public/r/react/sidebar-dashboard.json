{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "sidebar-dashboard",
  "title": "Sidebar dashboard",
  "description": "A copy-owned desktop dashboard shell with collapsible and resizable moduix navigation.",
  "dependencies": ["@moduix/react", "lucide-react"],
  "files": [
    {
      "path": "apps/docs/src/components/blocks/sidebar-dashboard.tsx",
      "content": "import { Button, Card, Collapsible, Menu, Sidebar } from '@moduix/react';\nimport { ChevronsUpDown, FileText, FolderOpen, Gauge, Settings, Users } from 'lucide-react';\nimport styles from './sidebar-dashboard.module.css';\nimport '@moduix/react/style.css';\n\nexport function SidebarDashboard() {\n  return (\n    <Sidebar className={styles.root}>\n      <Sidebar.Panel>\n        <Sidebar.Header>\n          <a className={styles.brand} href=\"#overview\">\n            <span className={styles.brandMark} data-sidebar-icon>\n              M\n            </span>\n            <Sidebar.Label>Moduix</Sidebar.Label>\n          </a>\n        </Sidebar.Header>\n\n        <Sidebar.Content>\n          <Sidebar.Group>\n            <Sidebar.GroupLabel>Workspace</Sidebar.GroupLabel>\n            <Sidebar.Menu>\n              <Sidebar.MenuItem>\n                <Sidebar.Tooltip content=\"Overview\">\n                  <Sidebar.MenuButton asChild active>\n                    <a href=\"#overview\">\n                      <Gauge />\n                      <Sidebar.Label>Overview</Sidebar.Label>\n                    </a>\n                  </Sidebar.MenuButton>\n                </Sidebar.Tooltip>\n              </Sidebar.MenuItem>\n              <Sidebar.MenuItem>\n                <Collapsible defaultOpen>\n                  <Sidebar.Tooltip content=\"Projects\">\n                    <Collapsible.Trigger asChild>\n                      <Sidebar.MenuButton>\n                        <FolderOpen />\n                        <Sidebar.Label>Projects</Sidebar.Label>\n                        <Collapsible.Indicator />\n                      </Sidebar.MenuButton>\n                    </Collapsible.Trigger>\n                  </Sidebar.Tooltip>\n                  <Collapsible.Content>\n                    <Sidebar.MenuSub>\n                      <Sidebar.MenuSubItem>\n                        <Sidebar.MenuSubButton href=\"#website\">Website</Sidebar.MenuSubButton>\n                      </Sidebar.MenuSubItem>\n                      <Sidebar.MenuSubItem>\n                        <Sidebar.MenuSubButton href=\"#mobile-app\">Mobile app</Sidebar.MenuSubButton>\n                      </Sidebar.MenuSubItem>\n                    </Sidebar.MenuSub>\n                  </Collapsible.Content>\n                </Collapsible>\n              </Sidebar.MenuItem>\n              <Sidebar.MenuItem>\n                <Sidebar.Tooltip content=\"Documents\">\n                  <Sidebar.MenuButton asChild>\n                    <a href=\"#documents\">\n                      <FileText />\n                      <Sidebar.Label>Documents</Sidebar.Label>\n                    </a>\n                  </Sidebar.MenuButton>\n                </Sidebar.Tooltip>\n              </Sidebar.MenuItem>\n            </Sidebar.Menu>\n          </Sidebar.Group>\n\n          <Sidebar.Group>\n            <Sidebar.GroupLabel>Manage</Sidebar.GroupLabel>\n            <Sidebar.Menu>\n              <Sidebar.MenuItem>\n                <Sidebar.Tooltip content=\"Team\">\n                  <Sidebar.MenuButton asChild>\n                    <a href=\"#team\">\n                      <Users />\n                      <Sidebar.Label>Team</Sidebar.Label>\n                    </a>\n                  </Sidebar.MenuButton>\n                </Sidebar.Tooltip>\n              </Sidebar.MenuItem>\n              <Sidebar.MenuItem>\n                <Sidebar.Tooltip content=\"Settings\">\n                  <Sidebar.MenuButton asChild>\n                    <a href=\"#settings\">\n                      <Settings />\n                      <Sidebar.Label>Settings</Sidebar.Label>\n                    </a>\n                  </Sidebar.MenuButton>\n                </Sidebar.Tooltip>\n              </Sidebar.MenuItem>\n            </Sidebar.Menu>\n          </Sidebar.Group>\n        </Sidebar.Content>\n\n        <Sidebar.Footer>\n          <Sidebar.Menu>\n            <Sidebar.MenuItem>\n              <Menu positioning={{ placement: 'right-end', gutter: 8, flip: false }}>\n                <Menu.Trigger asChild>\n                  <Sidebar.MenuButton size=\"lg\" aria-label=\"Open workspace menu\" title=\"Workspace\">\n                    <span className={styles.workspaceMark} data-sidebar-icon>\n                      AC\n                    </span>\n                    <Sidebar.Label>Acme Inc.</Sidebar.Label>\n                    <Menu.Indicator>\n                      <ChevronsUpDown />\n                    </Menu.Indicator>\n                  </Sidebar.MenuButton>\n                </Menu.Trigger>\n                <Menu.Positioner>\n                  <Menu.Content className={styles.workspaceMenu}>\n                    <Menu.Item value=\"workspace-settings\">\n                      <Menu.ItemText>\n                        <Menu.ItemTextContent>\n                          <Menu.ItemTextIcon>\n                            <Settings />\n                          </Menu.ItemTextIcon>\n                          <Menu.ItemTextLabel>Workspace settings</Menu.ItemTextLabel>\n                        </Menu.ItemTextContent>\n                      </Menu.ItemText>\n                    </Menu.Item>\n                    <Menu.Item value=\"manage-members\">\n                      <Menu.ItemText>\n                        <Menu.ItemTextContent>\n                          <Menu.ItemTextIcon>\n                            <Users />\n                          </Menu.ItemTextIcon>\n                          <Menu.ItemTextLabel>Manage members</Menu.ItemTextLabel>\n                        </Menu.ItemTextContent>\n                      </Menu.ItemText>\n                    </Menu.Item>\n                  </Menu.Content>\n                </Menu.Positioner>\n              </Menu>\n            </Sidebar.MenuItem>\n          </Sidebar.Menu>\n        </Sidebar.Footer>\n      </Sidebar.Panel>\n\n      <Sidebar.ResizeTrigger />\n      <Sidebar.Trigger />\n\n      <Sidebar.Inset>\n        <main className={styles.content} id=\"overview\">\n          <header className={styles.header}>\n            <div>\n              <p className={styles.eyebrow}>Workspace</p>\n              <h1>Overview</h1>\n              <p className={styles.description}>\n                Everything your team is working on, in one place.\n              </p>\n            </div>\n            <Button size=\"sm\">New project</Button>\n          </header>\n\n          <section className={styles.metrics} id=\"projects\" aria-label=\"Workspace summary\">\n            <Card size=\"sm\">\n              <Card.Body className={styles.metric}>\n                <span>Active projects</span>\n                <strong>12</strong>\n              </Card.Body>\n            </Card>\n            <Card size=\"sm\">\n              <Card.Body className={styles.metric}>\n                <span>Team members</span>\n                <strong>8</strong>\n              </Card.Body>\n            </Card>\n            <Card size=\"sm\">\n              <Card.Body className={styles.metric}>\n                <span>Open tasks</span>\n                <strong>24</strong>\n              </Card.Body>\n            </Card>\n          </section>\n\n          <Card className={styles.activity} size=\"sm\">\n            <Card.Body className={styles.activityBody}>\n              <strong>Keep moving</strong>\n              <span>Create a project to start sharing work with your team.</span>\n            </Card.Body>\n          </Card>\n        </main>\n      </Sidebar.Inset>\n    </Sidebar>\n  );\n}",
      "type": "registry:component",
      "target": "@components/blocks/sidebar-dashboard.tsx"
    },
    {
      "path": "apps/docs/src/components/blocks/sidebar-dashboard.module.css",
      "content": ".root {\n  --sidebar-width: min(100%, 64rem);\n  --sidebar-height: 38rem;\n  --sidebar-min-height: 30rem;\n  --sidebar-radius: var(--radius-lg);\n  --sidebar-shadow: var(--shadow-sm);\n}\n\n.brand {\n  display: flex;\n  align-items: center;\n  gap: var(--spacing-2);\n  min-width: 0;\n  color: inherit;\n  font-weight: var(--weight-semibold);\n  text-decoration: none;\n}\n\n.brandMark {\n  display: grid;\n  flex: none;\n  place-items: center;\n  width: var(--size-sm);\n  height: var(--size-sm);\n  border-radius: var(--radius-sm);\n  background-color: var(--color-primary);\n  color: var(--color-primary-foreground);\n  font-size: var(--text-xs);\n}\n\n.workspaceMark {\n  display: grid;\n  flex: none;\n  place-items: center;\n  width: var(--size-sm);\n  height: var(--size-sm);\n  border-radius: var(--radius-sm);\n  background-color: var(--color-muted);\n  color: var(--color-foreground);\n  font-size: var(--text-xs);\n  font-weight: var(--weight-semibold);\n}\n\n.workspaceMenu {\n  --menu-popup-min-width: 14rem;\n}\n\n.content {\n  display: grid;\n  gap: var(--spacing-6);\n  min-height: 100%;\n  padding: var(--spacing-6);\n}\n\n.header {\n  display: flex;\n  flex-wrap: wrap;\n  align-items: flex-start;\n  justify-content: space-between;\n  gap: var(--spacing-4);\n}\n\n.header h1,\n.header p {\n  margin: 0;\n}\n\n.header h1 {\n  margin-block-start: var(--spacing-1);\n  font-size: var(--text-2xl);\n  line-height: var(--line-height-text-2xl);\n}\n\n.eyebrow {\n  color: var(--color-muted-foreground);\n  font-size: var(--text-sm);\n  font-weight: var(--weight-medium);\n}\n\n.header .description {\n  margin-block-start: var(--spacing-2);\n  color: var(--color-muted-foreground);\n}\n\n.metrics {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: var(--spacing-4);\n}\n\n.metric {\n  display: grid;\n  gap: var(--spacing-2);\n  justify-items: center;\n  text-align: center;\n}\n\n.metric span {\n  color: var(--color-muted-foreground);\n  font-size: var(--text-sm);\n}\n\n.metric strong {\n  font-size: var(--text-3xl);\n  line-height: var(--line-height-text-3xl);\n}\n\n.activity {\n  align-self: start;\n}\n\n.activityBody {\n  display: grid;\n  gap: var(--spacing-1);\n}\n\n.activityBody strong {\n  color: var(--color-foreground);\n}\n\n@media (width < 40rem) {\n  .content {\n    padding: var(--spacing-4);\n  }\n\n  .metrics {\n    grid-template-columns: 1fr;\n  }\n}",
      "type": "registry:file",
      "target": "@components/blocks/sidebar-dashboard.module.css"
    }
  ],
  "type": "registry:block"
}