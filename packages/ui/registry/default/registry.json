{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "moduix-default",
  "homepage": "https://github.com/Blinks44/moduix",
  "items": [
    {
      "name": "init",
      "type": "registry:base",
      "title": "moduix init",
      "description": "Initialize shadcn for moduix and install the shared foundation files.",
      "extends": "none",
      "dependencies": ["@base-ui/react", "clsx"],
      "registryDependencies": ["core"]
    },
    {
      "name": "core",
      "type": "registry:item",
      "title": "moduix core",
      "description": "Shared styles, utilities, and icons for moduix registry components.",
      "dependencies": ["clsx", "@base-ui/react"],
      "docs": "Import '@/lib/moduix/styles/style.css' once in your app entry.",
      "files": [
        {
          "path": "lib/moduix/mergeClassName.ts",
          "target": "@lib/moduix/mergeClassName.ts",
          "type": "registry:lib"
        },
        {
          "path": "lib/moduix/icons/ui/index.ts",
          "target": "@lib/moduix/icons/ui/index.ts",
          "type": "registry:lib"
        },
        {
          "path": "lib/moduix/icons/ui/Icons.tsx",
          "target": "@lib/moduix/icons/ui/Icons.tsx",
          "type": "registry:lib"
        },
        {
          "path": "lib/moduix/styles/animations.css",
          "target": "@lib/moduix/styles/animations.css",
          "type": "registry:file"
        },
        {
          "path": "lib/moduix/styles/borders.css",
          "target": "@lib/moduix/styles/borders.css",
          "type": "registry:file"
        },
        {
          "path": "lib/moduix/styles/colors.css",
          "target": "@lib/moduix/styles/colors.css",
          "type": "registry:file"
        },
        {
          "path": "lib/moduix/styles/opacity.css",
          "target": "@lib/moduix/styles/opacity.css",
          "type": "registry:file"
        },
        {
          "path": "lib/moduix/styles/radius.css",
          "target": "@lib/moduix/styles/radius.css",
          "type": "registry:file"
        },
        {
          "path": "lib/moduix/styles/shadows.css",
          "target": "@lib/moduix/styles/shadows.css",
          "type": "registry:file"
        },
        {
          "path": "lib/moduix/styles/sizing.css",
          "target": "@lib/moduix/styles/sizing.css",
          "type": "registry:file"
        },
        {
          "path": "lib/moduix/styles/spacing.css",
          "target": "@lib/moduix/styles/spacing.css",
          "type": "registry:file"
        },
        {
          "path": "lib/moduix/styles/style.css",
          "target": "@lib/moduix/styles/style.css",
          "type": "registry:file"
        },
        {
          "path": "lib/moduix/styles/theme.css",
          "target": "@lib/moduix/styles/theme.css",
          "type": "registry:file"
        },
        {
          "path": "lib/moduix/styles/transforms.css",
          "target": "@lib/moduix/styles/transforms.css",
          "type": "registry:file"
        },
        {
          "path": "lib/moduix/styles/transitions.css",
          "target": "@lib/moduix/styles/transitions.css",
          "type": "registry:file"
        },
        {
          "path": "lib/moduix/styles/typography.css",
          "target": "@lib/moduix/styles/typography.css",
          "type": "registry:file"
        },
        {
          "path": "lib/moduix/styles/z-index.css",
          "target": "@lib/moduix/styles/z-index.css",
          "type": "registry:file"
        }
      ]
    },
    {
      "name": "accordion",
      "type": "registry:item",
      "title": "Accordion",
      "description": "moduix Accordion component.",
      "dependencies": ["@base-ui/react", "clsx"],
      "registryDependencies": ["core"],
      "files": [
        {
          "path": "ui/accordion/Accordion.tsx",
          "target": "@components/moduix/accordion/Accordion.tsx",
          "type": "registry:component"
        },
        {
          "path": "ui/accordion/Accordion.module.css",
          "target": "@components/moduix/accordion/Accordion.module.css",
          "type": "registry:file"
        },
        {
          "path": "ui/accordion/index.ts",
          "target": "@components/moduix/accordion/index.ts",
          "type": "registry:component"
        }
      ]
    },
    {
      "name": "button",
      "type": "registry:item",
      "title": "Button",
      "description": "moduix Button component.",
      "dependencies": ["@base-ui/react"],
      "registryDependencies": ["core"],
      "files": [
        {
          "path": "ui/button/Button.tsx",
          "target": "@components/moduix/button/Button.tsx",
          "type": "registry:component"
        },
        {
          "path": "ui/button/Button.module.css",
          "target": "@components/moduix/button/Button.module.css",
          "type": "registry:file"
        },
        {
          "path": "ui/button/index.ts",
          "target": "@components/moduix/button/index.ts",
          "type": "registry:component"
        }
      ]
    }
  ]
