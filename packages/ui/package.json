{
  "name": "moduix",
  "version": "0.9.0",
  "description": "Composable React UI components built on Base UI primitives.",
  "keywords": [
    "accessible",
    "base-ui",
    "component-library",
    "components",
    "css-modules",
    "design-system",
    "headless",
    "react",
    "typescript",
    "ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Blinks44/moduix",
    "directory": "packages/ui"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/index.css",
    "./reset.css": "./dist/reset.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "build": "tsc -b && vite build",
    "build-storybook": "storybook build",
    "tsc:check": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "globals": "^17.6.0",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vite-plugin-svgr": "^5.2.0"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.4.0",
    "react": "^17 || ^18 || ^19",
    "react-dom": "^17 || ^18 || ^19"
  }
}