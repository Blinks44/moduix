{
  "name": "@moduix/react",
  "version": "2.2.2",
  "description": "React implementation of the moduix component system, built on Ark UI primitives.",
  "keywords": [
    "accessible",
    "ark-ui",
    "component-library",
    "components",
    "css-modules",
    "design-system",
    "headless",
    "react",
    "typescript",
    "ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blinks44/moduix.git",
    "directory": "packages/react"
  },
  "files": [
    "dist",
    "LICENSE.md"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/styles/style.css",
    "./reset.css": "./dist/styles/reset.css",
    "./presets/contrast.css": "./dist/presets/contrast.css",
    "./presets/dense.css": "./dist/presets/dense.css",
    "./presets/soft.css": "./dist/presets/soft.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rslib",
    "build:storybook": "storybook build",
    "dev": "rslib --watch",
    "storybook": "storybook dev -p 6006 --no-open",
    "test": "rstest run",
    "test:watch": "rstest --watch",
    "tsc:check": "tsc --noEmit"
  },
  "dependencies": {
    "@unpic/react": "^1.0.2",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@ark-ui/react": "^5.37.2",
    "@internationalized/date": "^3.12.2",
    "@microsoft/api-extractor": "^7.58.12",
    "@rsbuild/core": "~2.1.4",
    "@rsbuild/plugin-react": "^2.1.0",
    "@rslib/core": "^0.23.2",
    "@rstest/adapter-rslib": "^0.10.6",
    "@rstest/core": "^0.10.6",
    "@storybook/addon-docs": "10.5.3",
    "@storybook/react": "10.5.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "10.5.3",
    "storybook-addon-rslib": "^3.3.4",
    "storybook-react-rsbuild": "^3.3.4",
    "typescript": "~6.0.3"
  },
  "peerDependencies": {
    "@ark-ui/react": "^5.37.2",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  }
}