{
  "name": "@moduix/react",
  "version": "1.0.5",
  "description": "Composable React UI components built on Ark UI primitives.",
  "keywords": [
    "accessible",
    "ark-ui",
    "component-library",
    "components",
    "css-modules",
    "design-system",
    "headless",
    "react",
    "typescript",
    "ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blinks44/moduix.git",
    "directory": "packages/react"
  },
  "files": [
    "dist",
    "LICENSE.md"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/core/styles/style.css",
    "./reset.css": "./dist/core/styles/reset.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "build": "tsdown",
    "build-storybook": "storybook build",
    "tsc:check": "tsc -b"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@ark-ui/react": "^5.37.2",
    "@tsdown/css": "^0.22.3",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-react": "^6.0.3",
    "globals": "^17.7.0",
    "tsdown": "^0.22.3",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-svgr": "^5.2.0"
  },
  "peerDependencies": {
    "@ark-ui/react": "^5.37.2",
    "react": "^17 || ^18 || ^19",
    "react-dom": "^17 || ^18 || ^19"
  }
}